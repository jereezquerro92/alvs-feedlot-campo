{
  "_comment": "Glob -> live-doc wikilinks. A file's link set is the ordered union of every matching rule. Governed by [[adr-17-live-doc-backlinks]]; this manifest owns the mapping (an ADR states rules, never information, per adr-00). Edit here, then re-run link.py to re-sync every block and CODEMAP.md.",
  "roots": ["backend", "frontend", "compose.yaml"],
  "exclude_dirs": [".venv", "node_modules", ".astro", "__pycache__", "dist", ".git", "migrations", "kdx-live-doc"],
  "rules": [
    { "glob": "backend/**/*.py", "links": ["BACKEND"] },
    { "glob": "backend/config/settings.py", "links": ["adr-02-initial-stack", "adr-06-cache", "adr-16-async-mandatory", "VARIABLES"] },
    { "glob": "backend/config/asgi.py", "links": ["adr-16-async-mandatory", "INFRASTRUCTURE"] },
    { "glob": "backend/config/throttling.py", "links": ["adr-06-cache", "CACHE"] },
    { "glob": "backend/config/middleware.py", "links": ["adr-06-cache", "CACHE"] },
    { "glob": "backend/config/*.py", "links": ["adr-02-initial-stack"] },
    { "glob": "backend/apps/users/*.py", "links": ["adr-10-auth", "AUTH"] },
    { "glob": "backend/apps/router/*.py", "links": ["adr-15-chatbot-two-tier", "adr-16-async-mandatory", "CHATBOT"] },
    { "glob": "backend/apps/m365/**/*.py", "links": ["adr-13-m365-graph"] },
    { "glob": "backend/apps/health/**/*.py", "links": ["adr-06-cache", "CACHE"] },
    { "glob": "backend/**/models.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/views.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/viewsets.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/serializers.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/urls.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/api_urls.py", "links": ["adr-03-api-and-backend", "API"] },
    { "glob": "backend/**/permissions.py", "links": ["adr-03-api-and-backend", "adr-10-auth", "API"] },
    { "glob": "backend/apps/users/oidc.py", "links": ["adr-10-auth", "API"] },
    { "glob": "backend/apps/m365/graph.py", "links": ["adr-13-m365-graph", "API"] },
    { "glob": "backend/**/*.html", "links": ["adr-05-htmx", "HTMX", "API"] },
    { "glob": "frontend/src/**/*.astro", "links": ["adr-04-frontend-and-design-system", "FRONTEND"] },
    { "glob": "frontend/src/**/*.svelte", "links": ["adr-04-frontend-and-design-system", "FRONTEND", "DESIGN-SYSTEM"] },
    { "glob": "frontend/src/**/*.ts", "links": ["adr-04-frontend-and-design-system", "FRONTEND"] },
    { "glob": "frontend/src/**/ui/**/*.svelte", "links": ["adr-04-frontend-and-design-system", "DESIGN-SYSTEM"] },
    { "glob": "frontend/src/**/ui/**/*.ts", "links": ["adr-04-frontend-and-design-system", "DESIGN-SYSTEM"] },
    { "glob": "frontend/src/pages/chatui.astro", "links": ["adr-15-chatbot-two-tier", "CHATBOT"] },
    { "glob": "frontend/src/lib/components/chat/*.svelte", "links": ["adr-15-chatbot-two-tier", "CHATBOT"] },
    { "glob": "frontend/src/lib/csrf.ts", "links": ["adr-10-auth", "adr-05-htmx"] },
    { "glob": "frontend/src/lib/theme.ts", "links": ["DESIGN-SYSTEM", "MELT-UI"] },
    { "glob": "frontend/src/lib/components/theme/ThemeModeToggle.svelte", "links": ["MELT-UI"] },
    { "glob": "frontend/src/lib/components/theme/ThemeCard.svelte", "links": ["MELT-UI"] },
    { "glob": "frontend/src/middleware.ts", "links": ["adr-10-auth", "INFRASTRUCTURE"] },
    { "glob": "compose.yaml", "links": ["adr-09-docker-compose", "DOCKER"] }
  ]
}

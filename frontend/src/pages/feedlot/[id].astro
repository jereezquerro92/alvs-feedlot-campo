---
/* LIVE-DOC:START — astro-drf-aws live-doc; see [[adr-17-live-doc-backlinks]]
 * Governed by: [[adr-04-frontend-and-design-system]]
 * Docs: [[FRONTEND]]
 * LIVE-DOC:END */
import Base from "../../layouts/Base.astro";
import { FeedlotDashboardView } from "$lib/components/views";
import SessionBadge from "$lib/components/auth/SessionBadge.svelte";
import { hasRole } from "$lib/auth";
import { requireRole } from "$lib/authGate";
import { t } from "../../i18n";
import type { Me } from "$lib/types/user";

const backendApiUrl = process.env.BACKEND_API_URL ?? "http://localhost:8000";
const publicBackendUrl = process.env.PUBLIC_BACKEND_URL ?? "http://localhost:8000";
const publicProjectSlug = process.env.PUBLIC_PROJECT_SLUG ?? "astro-drf-aws";

const { id } = Astro.params;
const cookie = Astro.request.headers.get("cookie");
const headers: Record<string, string> = cookie ? { cookie } : {};

let me: Me | null = null;
if (cookie) {
  try {
    const res = await fetch(`${backendApiUrl}/api/me/`, { headers });
    if (res.ok) me = (await res.json()) as Me;
  } catch (err) {
    console.error("SSR /api/me/ failed:", err);
  }
}

// Lobby gate ([[adr-20-authorization-lobby]] rule 1).
const redirect = requireRole(me);
if (redirect) return Astro.redirect(redirect);

async function getJson(path: string): Promise<any> {
  try {
    const res = await fetch(`${backendApiUrl}${path}`, { headers });
    if (!res.ok) return null;
    return await res.json();
  } catch (err) {
    console.error(`SSR ${path} failed:`, err);
    return null;
  }
}

const client = await getJson(`/api/clients/${id}/`);
// An unknown client id bounces back to the clients list, not a broken page.
if (!client) return Astro.redirect("/feedlot/");

const [summary, account, animalsData, lotsData, pricesData] = await Promise.all([
  getJson(`/api/clients/${id}/metrics/summary/`),
  getJson(`/api/clients/${id}/metrics/account/`),
  getJson(`/api/animals/?client=${id}`),
  getJson(`/api/lots/?client=${id}`),
  getJson(`/api/market-prices/?source=canuelas`),
]);

const asArray = (d: unknown): any[] =>
  Array.isArray(d) ? d : ((d as any)?.results ?? []);

const animals = asArray(animalsData);
const lots = asArray(lotsData);
const prices = asArray(pricesData);

const pending = me !== null && !hasRole(me);

Astro.response.headers.set("Cache-Control", "no-store");
---

<Base title={`${client.name} · ${t("feedlot_clients_title")}`}>
  <FeedlotDashboardView
    projectSlug={publicProjectSlug}
    client={client}
    summary={summary}
    account={account}
    prices={prices}
    animals={animals}
    lots={lots}
  >
    <SessionBadge
      client:load
      me={me}
      pending={pending}
      publicBackendUrl={publicBackendUrl}
      loginLabel={t("auth_login")}
      logoutLabel={t("auth_logout")}
      slot="session"
    />
  </FeedlotDashboardView>
</Base>
